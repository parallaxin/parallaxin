---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

let conflicts = [];
try {
  conflicts = (await getCollection('conflicts')).filter(a => !a.id.replace('.md', '').endsWith('.ar'));
} catch (e) {
  // Collection empty — expected during early build
}
const base = import.meta.env.BASE_URL;
---

<Base title="Conflict Records">
  <article style="max-width: 760px; margin: 0 auto; padding: 2rem 1.5rem;">

    <h1>Conflict Records</h1>
    <p style="color: var(--color-text-secondary); margin-bottom: 2rem; line-height: 1.7;">
      Documented timelines, actor involvement, and human cost of active and recent conflicts.
      Each record maps the parties, the events, and the distance between
      what was claimed and what was documented.
    </p>

    <div style="border-left: 4px solid var(--color-inference); padding: 0.75rem 1rem; margin-bottom: 2rem; background: var(--color-inference-bg); font-size: 0.85rem; color: var(--color-text-secondary); font-style: italic;">
      The selection of a start date is an editorial act. Events have documented antecedents.
      Every conflict record includes a framing note acknowledging this.
    </div>

    {conflicts.length === 0 ? (
      <div style="padding: 2rem; border: 1px dashed var(--color-border); text-align: center; color: var(--color-text-muted);">
        <p>Conflict records are being sourced and verified.</p>
        <p style="font-size: 0.85rem; margin-top: 0.5rem;">
          The pilot conflict record is in preparation.
          Timelines require multiple independent sources per event.
        </p>
      </div>
    ) : (
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        {conflicts.map((conflict) => (
          <a href={base + 'conflicts/' + conflict.id.replace('.md', '')}
             style="display: block; padding: 1.25rem; border: 1px solid var(--color-border); background: var(--color-surface); text-decoration: none; color: inherit;"
             class="card-link">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
              <span style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--color-text-muted);">
                {conflict.data.record_id}
              </span>
              <span style={`font-family: var(--font-mono); font-size: 0.65rem; font-weight: 700; padding: 0.15rem 0.4rem; border-radius: 2px; text-transform: uppercase; background: var(--color-gap-bg); color: var(--color-gap);`}>
                {conflict.data.status}
              </span>
            </div>
            <h2 style="font-size: 1.1rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--color-text-primary);">
              {conflict.data.name}
            </h2>
            <p style="font-size: 0.85rem; color: var(--color-text-secondary);">
              From {conflict.data.start_date} — {conflict.data.status === 'active' ? 'ongoing' : conflict.data.status}
            </p>
          </a>
        ))}
      </div>
    )}

  </article>
</Base>

<style>
  .card-link:hover {
    border-color: var(--color-documented) !important;
  }
</style>
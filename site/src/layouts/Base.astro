---
import { t, getDirection } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

interface Props {
  title?: string;
  locale?: Locale;
}

const { title, locale = 'en' } = Astro.props;
const dir = getDirection(locale);
const siteTitle = t(locale, 'site.title');
const pageTitle = title ? (title + ' | ' + siteTitle) : siteTitle;

const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL;

// Language switcher: compute alternate locale path
const isArabic = locale === 'ar';
const pathWithoutBase = currentPath.replace(base, '');
const altLocalePath = isArabic
  ? base + pathWithoutBase.replace(/^ar\/?/, '')  // Strip /ar/ prefix for English
  : base + 'ar/' + pathWithoutBase;               // Add /ar/ prefix for Arabic
const altLocaleLabel = isArabic ? 'EN' : 'عربي';
const localePrefix = isArabic ? 'ar/' : '';
---

<!DOCTYPE html>
<html lang={locale} dir={dir}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={t(locale, 'site.tagline')} />
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><circle cx='50' cy='50' r='40' fill='none' stroke='%2322c55e' stroke-width='6'/><circle cx='50' cy='50' r='4' fill='%2322c55e'/></svg>" />
  <title>{pageTitle}</title>
  <link rel="stylesheet" href={base + "styles/global.css"} />
</head>
<body>
  <header class="site-header">
    <div class="site-header-inner">
      <a href={base + (isArabic ? 'ar/' : '')} class="site-logo">
        <span class="site-logo-dot"></span>
        Parallaxin
      </a>
      <nav class="site-nav">
        <a href={base + localePrefix + 'conflicts'} class:list={[{ active: currentPath.startsWith(base + localePrefix + 'conflicts') }]}>
          {t(locale, 'site.nav.conflicts')}
        </a>
        <a href={base + localePrefix + 'actors'} class:list={[{ active: currentPath.startsWith(base + localePrefix + 'actors') }]}>
          {t(locale, 'site.nav.actors')}
        </a>
        <a href={base + localePrefix + 'autopsies'} class:list={[{ active: currentPath.startsWith(base + localePrefix + 'autopsies') }]}>
          {t(locale, 'site.nav.autopsies')}
        </a>
        <a href={base + localePrefix + 'constitution'} class:list={[{ active: currentPath === base + localePrefix + 'constitution' }]}>
          {t(locale, 'site.nav.constitution')}
        </a>
        <a href="https://github.com/parallaxin/parallaxin"
           target="_blank" rel="noopener"
           class="site-nav-github">
          GitHub
        </a>
        <a href={altLocalePath} class="site-nav-lang">
          {altLocaleLabel}
        </a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="site-footer-inner">
      <p>{t(locale, 'footer.constitution_link')}</p>
      <p>
        <a href={base + localePrefix + 'about'}>{t(locale, 'site.nav.about')}</a> ·
        <a href={base + localePrefix + 'terms'}>{t(locale, 'footer.terms') || 'Terms'}</a> ·
        <a href="https://github.com/parallaxin/parallaxin">GitHub</a>
      </p>
      <p>Code: MIT · Content: CC-BY 4.0</p>
      <p>{t(locale, 'footer.no_tracking')}</p>
    </div>
  </footer>
</body>
</html>